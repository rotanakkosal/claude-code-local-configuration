# aiclab LiteLLM Configuration

# Database URL (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# LiteLLM Master Key (Admin)
LITELLM_MASTER_KEY=your-master-key-here

# User API Key (for remote users)
USER_API_KEY=your-generated-user-key

# Cloudflare Tunnel URL (changes when restarted)
TUNNEL_URL=https://your-tunnel-url.trycloudflare.com
